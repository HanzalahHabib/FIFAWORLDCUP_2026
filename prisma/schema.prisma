// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  passwordHash   String
  name           String
  gender         String?
  cohort         String     // "West Side" or "East Side"
  role           String     @default("USER") // "USER" or "ADMIN"
  points         Int        @default(0)
  manualPoints   Int        @default(0)
  
  // Bonus selections
  firstPlaceId   String?
  secondPlaceId  String?
  thirdPlaceId   String?
  fourthPlaceId  String?
  unbeatenTeamId String?
  noWinTeamId    String?

  picks          Pick[]
  pollVotes      PollVote[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([points])
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  group     String   // A-L
  flagUrl   String?
  
  homeMatches Match[]  @relation("HomeMatches")
  awayMatches Match[]  @relation("AwayMatches")

  pollVotes   PollVote[]
  pollsWon    Poll[]   @relation("PollResult")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id             String   @id @default(uuid())
  apiFootballId  Int?     @unique
  homeTeamId     String?
  awayTeamId     String?
  kickoffTimeUTC DateTime
  status         String   @default("SCHEDULED") // "SCHEDULED", "IN_PLAY", "FINISHED"
  homeScore      Int?
  awayScore      Int?
  round          String   @default("group-stage") // "group-stage", "round-of-32", "round-of-16", "quarter-finals", "semi-finals", "third-place", "final"
  homeTeamLabel  String?  // For knockout TBD slots: e.g. "Group A winners"
  awayTeamLabel  String?  // For knockout TBD slots: e.g. "Group B runners-up"

  homeTeam       Team?    @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam       Team?    @relation("AwayMatches", fields: [awayTeamId], references: [id])

  picks          Pick[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([kickoffTimeUTC])
  @@index([round])
}

model Pick {
  id             String   @id @default(uuid())
  userId         String
  matchId        String
  prediction     String   // "HOME", "AWAY", "DRAW"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  match          Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model Settings {
  id                   String    @id @default("global")
  matchesShowDays      Int       @default(2)
  championPickDeadline DateTime?
  actualChampionId     String?
  actualUnbeatenTeamId String?
  actualNoWinTeamId    String?
  updatedAt            DateTime  @updatedAt
}

model Poll {
  id           String     @id @default(uuid())
  question     String
  isActive     Boolean    @default(false)
  options      String[]   @default([])
  resultTeamId String?
  resultOption String?
  
  votes        PollVote[]
  resultTeam   Team?      @relation("PollResult", fields: [resultTeamId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PollVote {
  id        String   @id @default(uuid())
  pollId    String
  userId    String
  teamId    String?
  option    String?
  
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([userId])
}
