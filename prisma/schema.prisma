// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  gender         String?
  cohort         String   // "US Team" or "PK Team"
  role           String   @default("USER") // "USER" or "ADMIN"
  points         Int      @default(0)
  
  // Bonus selections
  firstPlaceId   String?
  secondPlaceId  String?
  thirdPlaceId   String?
  fourthPlaceId  String?
  unbeatenTeamId String?
  noWinTeamId    String?

  picks          Pick[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  group     String   // A-L
  flagUrl   String?
  
  homeMatches Match[]  @relation("HomeMatches")
  awayMatches Match[]  @relation("AwayMatches")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id             String   @id @default(uuid())
  apiFootballId  Int?     @unique
  homeTeamId     String?
  awayTeamId     String?
  kickoffTimeUTC DateTime
  status         String   @default("SCHEDULED") // "SCHEDULED", "IN_PLAY", "FINISHED"
  homeScore      Int?
  awayScore      Int?

  homeTeam       Team?    @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam       Team?    @relation("AwayMatches", fields: [awayTeamId], references: [id])

  picks          Pick[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Pick {
  id             String   @id @default(uuid())
  userId         String
  matchId        String
  prediction     String   // "HOME", "AWAY", "DRAW"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  match          Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}
